{
  "name": "mi-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "node scripts/start-api.mjs",
    "start": "npm run api",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "api": "node scripts/start-api.mjs",
    "api:central": "node scripts/start-api-central.mjs",
    "migrate:mysql": "node scripts/migrate-to-mysql.mjs",
    "backup:state": "node scripts/backup-state.mjs",
    "restore:state": "node scripts/restore-state.mjs",
    "create-admin": "node scripts/create-admin.mjs",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.11.0",
    "mysql2": "^3.22.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9"
  },
  "build": {
    "appId": "com.ldsagro.erp",
    "productName": "LDS Agro ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
