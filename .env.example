ERP_STORAGE=auto
HOST=127.0.0.1
PORT=4000
# CORS_ORIGIN=* para permitir conexiones desde cualquier front local.
# Ejemplo seguro (1 solo origen): CORS_ORIGIN=http://192.168.1.50:5173
CORS_ORIGIN=*

# MySQL (usar cuando ERP_STORAGE=mysql o para auto-deteccion)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lds_agro_erp
MYSQL_POOL_SIZE=10
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_SSL=false
